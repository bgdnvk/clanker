FROM golang:1.25-alpine AS build

RUN apk add --no-cache ca-certificates git
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/clanker ./main.go

FROM alpine:3.22

RUN apk add --no-cache ca-certificates curl git openssh-client
COPY --from=build /out/clanker /usr/local/bin/clanker

ENTRYPOINT ["clanker"]
CMD ["sre", "run", "--sre", "--target", "docker"]
